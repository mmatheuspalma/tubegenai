    "primitiveProps": {
      "segments": [
        { "text": "When your dog barks at night", "startFrame": 0, "durationFrames": 43 },
        { "text": "you probably think they're just being loud.", "startFrame": 43, "durationFrames": 66 },
        { "text": "Maybe they heard something.", "startFrame": 109, "durationFrames": 41 },
        { "text": "Maybe they're bored.", "startFrame": 150, "durationFrames": 31 },
        { "text": "But what's actually happening is far more specific than most owners realize", "startFrame": 181, "durationFrames": 115 },
        { "text": "and it reveals something about your dog's internal state that you've likely been misreading for years.", "startFrame": 296, "durationFrames": 156 },
        { "text": "Dogs don't bark at night for the same reason they bark during the day.", "startFrame": 452, "durationFrames": 107 },
        { "text": "Their brain operates differently after dark.", "startFrame": 559, "durationFrames": 67 },
        { "text": "Canine sensory processing shifts significantly in low-light conditions.", "startFrame": 626, "durationFrames": 109 },
        { "text": "Their hearing becomes more acute.", "startFrame": 735, "durationFrames": 51 },
        { "text": "Their territorial instincts heighten.", "startFrame": 786, "durationFrames": 57 },
        { "text": "And their threshold for what feels threatening drops considerably.", "startFrame": 843, "durationFrames": 101 },
        { "text": "That random bark at two in the morning isn't random at all.", "startFrame": 944, "durationFrames": 89 }
      ],
